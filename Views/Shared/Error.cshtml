@model ErrorViewModel
@{
    ViewData["Title"] = "Lỗi";
}

<h1 class="text-danger">Đã có lỗi xảy ra.</h1>
<h2 class="text-danger">Không thể xử lý yêu cầu của bạn lúc này.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Mã yêu cầu:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>Chế độ phát triển</h3>
<p>
    Khi chạy ở môi trường <strong>Development</strong>, hệ thống sẽ hiển thị thêm thông tin chi tiết về lỗi.
</p>
<p>
    <strong>Không nên bật môi trường Development khi triển khai thật.</strong>
    Việc này có thể làm lộ thông tin nhạy cảm từ lỗi hệ thống cho người dùng cuối.
</p>
