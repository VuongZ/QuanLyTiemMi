@model KhachHang

@{
    ViewData["Title"] = "Đăng ký làm mi";
    var minDate = DateTime.Today.ToString("yyyy-MM-dd");
    var selectedTime = ViewData["SelectedTime"] as string ?? "09:00";
    var showForm = !ViewData.ModelState.IsValid;
    var slots = ViewData["Slots"] as IReadOnlyList<BookingSlotViewModel> ?? [];
}

<section class="booking-hero">
    <div class="booking-copy">
        <p class="eyebrow">TinMI Lash Studio</p>
        <h1>Đặt lịch làm mi nhanh gọn</h1>
        <p class="lead">Mỗi lịch làm mi giữ chỗ trong 2 tiếng. Những giờ đã trùng lịch sẽ tự tối đi để bạn chọn giờ còn trống.</p>

        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="alert alert-success booking-alert" role="alert">@successMessage</div>
        }

        <button type="button" class="btn btn-dark booking-open-button" id="openBookingForm">
            Đặt lịch làm mi ngay
        </button>
    </div>

    <form asp-action="Index" method="post" class="booking-form @(showForm ? "" : "booking-form-hidden")" id="bookingForm">
        @Html.AntiForgeryToken()

        <h2>Thông tin đặt lịch</h2>

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="TenKh" class="form-label"></label>
            <input asp-for="TenKh" class="form-control" placeholder="Ví dụ: Nguyễn Thanh Mi" autocomplete="name" />
            <span asp-validation-for="TenKh" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Sdt" class="form-label"></label>
            <input asp-for="Sdt" class="form-control" placeholder="Ví dụ: 0901234567" autocomplete="tel" />
            <span asp-validation-for="Sdt" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="NgayDK" class="form-label"></label>
            <input asp-for="NgayDK" type="date" class="form-control" id="bookingDate" min="@minDate" value="@Model.NgayDK.ToString("yyyy-MM-dd")" />
            <span asp-validation-for="NgayDK" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label class="form-label">Bảng chọn giờ</label>
            <input type="hidden" name="gioDK" id="gioDK" value="@selectedTime" />
            <div class="slot-board" id="slotBoard">
                @foreach (var group in slots.GroupBy(slot => slot.Session))
                {
                    <div class="slot-section">
                        <p class="slot-section-title">@group.Key</p>
                        <div class="slot-grid">
                            @foreach (var slot in group)
                            {
                                var isSelected = slot.Time == selectedTime && slot.IsAvailable;
                                <button
                                    type="button"
                                    class="slot-button @(slot.IsAvailable ? "" : "slot-button-booked") @(isSelected ? "slot-button-selected" : "")"
                                    data-time="@slot.Time"
                                    disabled="@(!slot.IsAvailable)">
                                    @slot.Label
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
            <div class="form-text">Mỗi lịch kéo dài 2 tiếng. Giờ tối là giờ đã có khách hoặc bị trùng lịch.</div>
            @Html.ValidationMessage("gioDK", null, new { @class = "text-danger" })
        </div>

        <button type="submit" class="btn btn-dark w-100">Gửi đăng ký</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const openButton = document.getElementById('openBookingForm');
            const form = document.getElementById('bookingForm');
            const nameInput = document.getElementById('TenKh');
            const dateInput = document.getElementById('bookingDate');
            const slotBoard = document.getElementById('slotBoard');
            const selectedTimeInput = document.getElementById('gioDK');

            const openForm = () => {
                form?.classList.remove('booking-form-hidden');
                form?.scrollIntoView({ behavior: 'smooth', block: 'center' });
                window.setTimeout(() => nameInput?.focus(), 350);
            };

            const selectSlot = (button) => {
                if (!button || button.disabled) return;
                selectedTimeInput.value = button.dataset.time || '';
                slotBoard.querySelectorAll('.slot-button-selected').forEach((item) => {
                    item.classList.remove('slot-button-selected');
                });
                button.classList.add('slot-button-selected');
            };

            const bindSlotButtons = () => {
                slotBoard.querySelectorAll('.slot-button').forEach((button) => {
                    button.addEventListener('click', () => selectSlot(button));
                });
            };

            const renderSlots = (slots) => {
                const groups = slots.reduce((result, slot) => {
                    result[slot.session] = result[slot.session] || [];
                    result[slot.session].push(slot);
                    return result;
                }, {});

                slotBoard.innerHTML = Object.entries(groups).map(([session, items]) => `
                    <div class="slot-section">
                        <p class="slot-section-title">${session}</p>
                        <div class="slot-grid">
                            ${items.map((slot) => `
                                <button
                                    type="button"
                                    class="slot-button ${slot.isAvailable ? '' : 'slot-button-booked'}"
                                    data-time="${slot.time}"
                                    ${slot.isAvailable ? '' : 'disabled'}>
                                    ${slot.label}
                                </button>
                            `).join('')}
                        </div>
                    </div>
                `).join('');

                const firstAvailable = slotBoard.querySelector('.slot-button:not(:disabled)');
                selectedTimeInput.value = firstAvailable?.dataset.time || '';
                if (firstAvailable) {
                    firstAvailable.classList.add('slot-button-selected');
                }
                bindSlotButtons();
            };

            openButton?.addEventListener('click', openForm);
            bindSlotButtons();

            dateInput?.addEventListener('change', async () => {
                selectedTimeInput.value = '';
                const response = await fetch(`/Home/Slots?date=${dateInput.value}`);
                renderSlots(await response.json());
            });
        })();
    </script>
}
