@model LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập quản lý";
}

<section class="admin-login">
    <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="login-form">
        @Html.AntiForgeryToken()

        <p class="eyebrow">Quản trị TinMI</p>
        <h1>Đăng nhập</h1>

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="User" class="form-label"></label>
            <input asp-for="User" class="form-control" autocomplete="username" />
            <span asp-validation-for="User" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Pass" class="form-label"></label>
            <input asp-for="Pass" class="form-control" autocomplete="current-password" />
            <span asp-validation-for="Pass" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-dark w-100">Đăng nhập</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
